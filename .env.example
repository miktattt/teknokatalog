PORT=3000

# JWT Secret — en az 32 karakterlik rastgele bir değer kullanın
# Örnek üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=buraya-cok-guclu-rastgele-bir-deger-yazin

# Admin hesabı (ilk çalıştırmada oluşturulur)
ADMIN_EMAIL=admin@sirketiniz.com
ADMIN_PASSWORD=GucluSifre123!
ADMIN_NAME=Admin

# CORS — Üretimde sitenizin adresini yazın (virgülle birden fazla)
# ALLOWED_ORIGINS=https://katalog.sirketiniz.com

# Domain (Nginx için)
DOMAIN=katalog.sirketiniz.com
